ninja_required_version = 1.3
cxx = c++
nvcc = /data/sopio/miniconda3/envs/instantsplatPP/bin/nvcc

cflags = -pthread -B /data/sopio/miniconda3/envs/instantsplatPP/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /data/sopio/miniconda3/envs/instantsplatPP/include -fPIC -O2 -isystem /data/sopio/miniconda3/envs/instantsplatPP/include -fPIC -I/data/sopio/miniconda3/envs/instantsplatPP/lib/python3.10/site-packages/torch/include -I/data/sopio/miniconda3/envs/instantsplatPP/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/data/sopio/miniconda3/envs/instantsplatPP/include -I/data/sopio/miniconda3/envs/instantsplatPP/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_C -std=c++17
cuda_cflags = -I/data/sopio/miniconda3/envs/instantsplatPP/lib/python3.10/site-packages/torch/include -I/data/sopio/miniconda3/envs/instantsplatPP/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/data/sopio/miniconda3/envs/instantsplatPP/include -I/data/sopio/miniconda3/envs/instantsplatPP/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_C -gencode=arch=compute_75,code=compute_75 -gencode=arch=compute_75,code=sm_75 -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /share/sopio/master_thesis/codebases/InstantSplatPP/submodules/simple-knn/build/temp.linux-x86_64-cpython-310/ext.o: compile /share/sopio/master_thesis/codebases/InstantSplatPP/submodules/simple-knn/ext.cpp
build /share/sopio/master_thesis/codebases/InstantSplatPP/submodules/simple-knn/build/temp.linux-x86_64-cpython-310/simple_knn.o: cuda_compile /share/sopio/master_thesis/codebases/InstantSplatPP/submodules/simple-knn/simple_knn.cu
build /share/sopio/master_thesis/codebases/InstantSplatPP/submodules/simple-knn/build/temp.linux-x86_64-cpython-310/spatial.o: cuda_compile /share/sopio/master_thesis/codebases/InstantSplatPP/submodules/simple-knn/spatial.cu








